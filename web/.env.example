# Required for non-BYOK use (owner mode, free trials).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OPTIONAL — override the model used by each route. Defaults are listed.
# ANALYZE_MODEL=opus
# ASK_MODEL=sonnet

# OPTIONAL — absolute path for saved-analysis JSON files. On Railway this
# should point at the mounted persistent volume (e.g. /data/saved-analyses).
# Locally, leave unset; defaults to ../output/saved-analyses.
# SAVED_ANALYSES_DIR=

# OPTIONAL — third-tier live-quote fallback after Yahoo and Stooq.
# FINNHUB_API_KEY=
